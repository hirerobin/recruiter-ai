# ─────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# HTTPS webhook URL (production only — leave empty to use long polling in dev)
TELEGRAM_WEBHOOK_URL=

# Random secret for webhook header validation (generate with: openssl rand -hex 32)
TELEGRAM_WEBHOOK_SECRET=

# Comma-separated Telegram chat IDs of authorized admins who can upload knowledge files
# e.g. 123456789,987654321
ADMIN_TELEGRAM_CHAT_IDS=

# Telegram chat ID of the recruiter to notify on escalations
RECRUITER_TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────

# OpenAI API key (used for GPT-4o + text-embedding-3-small)
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────
# Database (PostgreSQL + pgvector)
# ─────────────────────────────────────────────

# PostgreSQL connection string
# Local dev: postgresql://recruiter:recruiter_pass@localhost:5432/recruiter_ai
DATABASE_URL=postgresql://recruiter:recruiter_pass@localhost:5432/recruiter_ai

# ─────────────────────────────────────────────
# Google Sheets (candidate tracking)
# ─────────────────────────────────────────────

# Service account email from Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=bot@your-project.iam.gserviceaccount.com

# Private key from service account JSON (replace literal \n with actual newlines)
GOOGLE_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Spreadsheet ID from the Google Sheets URL
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Sheet/tab name within the spreadsheet (default: Candidates)
GOOGLE_SHEETS_SHEET_NAME=Candidates

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────

# development | production
NODE_ENV=development
